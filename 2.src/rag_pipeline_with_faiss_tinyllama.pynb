   "source": [
    "import faiss\n",
    "import json\n",
    "from sentence_transformers import SentenceTransformer\n",
    "from transformers import AutoTokenizer, AutoModelForCausalLM\n",
    "import torch\n",
    "\n",
    "# Load index and texts\n",
    "index = faiss.read_index(\"faiss_index1a.idx\")\n",
    "with open(\"texts_list.json\", \"r\", encoding=\"utf-8\") as f:\n",
    "    texts = json.load(f)\n",
    "\n",
    "embed_model = SentenceTransformer(\"all-MiniLM-L6-v2\")\n",
    "\n",
    "device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
    "tokenizer = AutoTokenizer.from_pretrained(\"TinyLlama/TinyLlama-1.1B-Chat-v1.0\")\n",
    "llama_model = AutoModelForCausalLM.from_pretrained(\"TinyLlama/TinyLlama-1.1B-Chat-v1.0\").to(device)\n",
    "\n",
    "def retrieve_top_k_chunks(query, k=5):\n",
    "    query_vec = embed_model.encode([query]).astype(\"float32\")\n",
    "    D, I = index.search(query_vec, k)\n",
    "    return [texts[i] for i in I[0]]\n",
    "\n",
    "def build_prompt(query, chunks):\n",
    "    context = \"\\n\\n\".join(chunks)\n",
    "    return f\"\"\"You are an intelligent assistant. Use the following context to answer the question clearly and briefly. If unsure, say \"I don't know\".\n",
    "\n",
    "Context:\n",
    "{context}\n",
    "\n",
    "Question: {query}\n",
    "\n",
    "Answer:\"\"\"\n",
    "\n",
    "def call_tiny_llama(prompt):\n",
    "    inputs = tokenizer(prompt, return_tensors=\"pt\").to(device)\n",
    "    with torch.no_grad():\n",
    "        outputs = llama_model.generate(**inputs, max_new_tokens=200)\n",
    "    return tokenizer.decode(outputs[0], skip_special_tokens=True)\n",
    "\n",
    "query = \"Who is Marieve Herington?\"\n",
    "chunks = retrieve_top_k_chunks(query)\n",
    "prompt = build_prompt(query, chunks)\n",
    "answer = call_tiny_llama(prompt)\n",
    "\n",
    "print(\"Answer:\")\n",
    "print(answer)\n"
   ]
  },
