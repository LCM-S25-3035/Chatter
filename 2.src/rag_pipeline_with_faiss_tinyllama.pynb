   "source": [
    "import pandas as pd\n",
    "from sentence_transformers import SentenceTransformer\n",
    "import faiss\n",
    "import numpy as np\n",
    "import json\n",
    "\n",
    "# 1. Load your chunked text CSV file\n",
    "csv_path = r\"C:\\Users\\choud\\Downloads\\wiki_hybrid_chunks_300.csv\"\n",
    "df = pd.read_csv(csv_path)\n",
    "\n",
    "# Make sure your CSV has a column named 'chunk_text'\n",
    "texts = df[\"chunk_text\"].tolist()\n",
    "\n",
    "print(f\"Loaded {len(texts)} text chunks.\")\n",
    "\n",
    "# 2. Load embedding model\n",
    "embed_model = SentenceTransformer(\"all-MiniLM-L6-v2\")\n",
    "\n",
    "# 3. Generate embeddings for all chunks\n",
    "print(\"Encoding text chunks...\")\n",
    "embeddings = embed_model.encode(texts, show_progress_bar=True)\n",
    "embeddings = embeddings.astype('float32')\n",
    "\n",
    "# 4. Create FAISS index\n",
    "dimension = embeddings.shape[1]\n",
    "index = faiss.IndexFlatL2(dimension)  # L2 distance index\n",
    "index.add(embeddings)\n",
    "\n",
    "print(f\"FAISS index created with {index.ntotal} vectors.\")\n",
    "\n",
    "# 5. Save the FAISS index\n",
    "faiss.write_index(index, \"faiss_index1a.idx\")\n",
    "print(\"FAISS index saved as faiss_index1a.idx\")\n",
    "\n",
    "# 6. Save texts separately so you can retrieve the original text by index later\n",
    "with open(\"texts_list.json\", \"w\", encoding=\"utf-8\") as f:\n",
    "    json.dump(texts, f, ensure_ascii=False, indent=2)\n",
    "print(\"Text chunks saved as texts_list.json\")\n"
   ]
  },
