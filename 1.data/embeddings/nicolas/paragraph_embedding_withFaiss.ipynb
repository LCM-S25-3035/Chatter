   "source": [
    "import faiss\n",
    "import pandas as pd\n",
    "from sentence_transformers import SentenceTransformer\n",
    "import numpy as np\n",
    "\n",
    "# Load FAISS index\n",
    "index = faiss.read_index(\"faiss_index.idx\")\n",
    "\n",
    "# Load metadata (filename + text)\n",
    "metadata = pd.read_csv(\"faiss_metadata.csv\")\n",
    "\n",
    "# Load embedding model (same as used before)\n",
    "model = SentenceTransformer('all-MiniLM-L6-v2')\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 14,
   "id": "caa3d7fb-4d13-4072-bf7e-31a0a3ea84ce",
   "metadata": {},
   "outputs": [],
   "source": [
    "def search_faiss(query, k=5):\n",
    "    # Embed the query text\n",
    "    query_vec = model.encode([query], show_progress_bar=False)\n",
    "    query_vec = np.array(query_vec).astype('float32')\n",
    "\n",
    "    # Search the index for top k similar vectors\n",
    "    distances, indices = index.search(query_vec, k)\n",
    "\n",
    "    results = []\n",
    "    for idx in indices[0]:\n",
    "        result = {\n",
    "            \"filename\": metadata.iloc[idx]['filename'],\n",
    "            \"text\": metadata.iloc[idx]['text']\n",
    "        }\n",
    "        results.append(result)\n",
    "    return results\n"
   ]
  },
