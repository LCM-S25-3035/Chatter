   "source": [
    "def paragraph_chunking(text, chunk_size=2, overlap=1):\n",
    "    paragraphs = re.split(r'\\n\\s*\\n', text.strip())\n",
    "    chunks = []\n",
    "    for i in range(0, len(paragraphs), chunk_size - overlap):\n",
    "        chunk = \"\\n\\n\".join(paragraphs[i:i + chunk_size])\n",
    "        if chunk.strip():\n",
    "            chunks.append(chunk.strip())\n",
    "    return chunks\n",
    "\n",
    "chunked_data = []\n",
    "\n",
    "for _, row in df.iterrows():\n",
    "    filename = row['filename']\n",
    "    text = row['text']\n",
    "    chunks = paragraph_chunking(text)\n",
    "    for chunk in chunks:\n",
    "        chunked_data.append({\"filename\": filename, \"chunk_text\": chunk})\n",
    "\n",
    "chunked_df = pd.DataFrame(chunked_data)\n",
    "chunked_df.to_csv(\"chunked_text_with_filenames.csv\", index=False)"
   ]
  },
